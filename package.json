{
  "name": "qq-automation",
  "version": "1.0.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "bridge": "node qq-bridge.js",
    "dev": "node --watch server.js",
    "build:win": "pkg server.js --targets node18-win-x64 --output QQ自动化系统.exe"
  },
  "dependencies": {
    "@yao-pkg/pkg": "^6.21.0",
    "express": "^4.18.0",
    "nexe": "^5.0.0-beta.4",
    "oicq": "^2.3.1"
  },
  "type": "module",
  "pkg": {
    "scripts": [
      "server.js",
      "modules/**/*.js"
    ],
    "assets": [
      "public/**/*",
      "data/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ]
  }
}